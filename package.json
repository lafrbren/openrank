{
  "name": "openrank",
  "version": "0.1.0",
  "description": "A local studio for building \"Top N\" countdown shorts for TikTok, YouTube Shorts, and Reels. What you see in the preview is what renders.",
  "type": "module",
  "license": "MIT",
  "author": "lafrbren (https://github.com/lafrbren)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lafrbren/openrank.git"
  },
  "homepage": "https://github.com/lafrbren/openrank#readme",
  "bugs": "https://github.com/lafrbren/openrank/issues",
  "keywords": [
    "video",
    "shorts",
    "tiktok",
    "youtube-shorts",
    "reels",
    "ffmpeg",
    "yt-dlp",
    "ranking",
    "countdown"
  ],
  "bin": {
    "openrank": "bin/openrank.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "server",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently -k \"node server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "node bin/openrank.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "quill": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.1",
    "zustand": "^4.5.4"
  }
}
